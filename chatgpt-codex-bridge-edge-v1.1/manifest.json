{
  "manifest_version": 3,
  "name": "ChatGPT Codex Bridge for Edge",
  "version": "0.2.0",
  "description": "Capture a context packet from ChatGPT in Microsoft Edge and send it to a local hub.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "ChatGPT Codex Bridge",
    "default_popup": "popup.html"
  }
}
